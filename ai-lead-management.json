        "jsCode": "const fullText = $input.first().json.choices[0].message.content;\n\n// Split out the subject line\nconst lines = fullText.split('\\n');\nlet subject = \"Following up on your inquiry\";\nlet bodyLines = lines;\n\nif (lines[0].toLowerCase().startsWith('subject:')) {\n  subject = lines[0].replace(/subject:/i, '').trim();\n  bodyLines = lines.slice(1);\n}\n\nconst body = bodyLines.join('\\n').trim();\n\nreturn {\n  recordId: $('Code in JavaScript').first().json.recordId,\n  email: $('Update record').first().json.fields.Email,\n  fullName: $('Update record').first().json.fields['Full Name'],\n  leadCategory: $('Update record').first().json.fields['Lead Category'],\n  emailSubject: subject,\n  emailBody: body\n};"
      },
