        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a professional sales development rep writing personalized follow-up emails to inbound leads. Keep emails concise (under 150 words), warm, and tailored to the lead's stated needs. Do not use generic templates.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Write a follow-up email for this lead:\\nName: {{ $json.fields['Full Name'] }}\\nCompany: {{ $json.fields['Company Name'] }}\\nJob Title: {{ $json.fields['Job Title'] }}\\nLead Category: {{ $json.fields['Lead Category'] }}\\nInquiry: {{ $json.fields['Inquiry Message'] }}\\n\\nIf the lead is Hot, convey urgency and offer a call this week. If Warm, be helpful and informative. If Cold, be low-pressure and educational. Sign off as 'The Sales Team'.\"\n    }\n  ]\n}",
