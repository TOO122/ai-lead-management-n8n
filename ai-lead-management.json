    {
      "parameters": {
        "jsCode": "const data = $input.first().json.fields;\n\nlet score = 0;\n\n// Budget scoring (max 50)\nconst budgetScores = {\n  \"Under $5k\": 10,\n  \"$5k-$20k\": 25,\n  \"$20k-$50k\": 40,\n  \"$50k+\": 50\n};\nscore += budgetScores[data[\"Budget\"]] || 0;\n\n// Company Size scoring (max 30)\nconst sizeScores = {\n  \"1-10\": 5,\n  \"11-50\": 15,\n  \"51-200\": 22,\n  \"201-500\": 27,\n  \"500+\": 30\n};\nscore += sizeScores[data[\"Company Size\"]] || 0;\n\n// Job Title scoring (max 20)\nconst jobTitle = (data[\"Job Title\"] || \"\").toLowerCase();\nif (jobTitle.includes(\"vp\") || jobTitle.includes(\"chief\") || jobTitle.includes(\"c-level\")) {\n  score += 20;\n} else if (jobTitle.includes(\"director\") || jobTitle.includes(\"head of\")) {\n  score += 14;\n} else if (jobTitle.includes(\"manager\")) {\n  score += 8;\n} else {\n  score += 3;\n}\n\n// Determine category\nlet category = \"Cold\";\nif (score >= 70) category = \"Hot\";\nelse if (score >= 40) category = \"Warm\";\n\nreturn {\n  recordId: $input.first().json.id,\n  leadScore: score,\n  leadCategory: category\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
